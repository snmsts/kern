# cl-pdf は独立した clone (origin = mbattyani/cl-pdf, branch local-fixes)。
# 独自の履歴を持つのでこのリポジトリには入れない。フォークとして分離する予定。
vendor/

# 生成物
*.pdf
*.fasl
*.dx32fsl
*.dx64fsl
demo/extracted.txt
demo/out-lines.txt

# TeX の生成物 (compare/ の ground-truth 比較)
*.aux
*.log
*.dvi
*.out
*.synctex.gz
*.ltjruby

# レンダリング成果物 (gs で PDF→PNG した目視確認用)
*.png
# README の showcase 画像だけは追跡する
!docs/*.png
